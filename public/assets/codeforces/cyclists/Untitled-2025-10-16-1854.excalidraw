      "updated": 1773752597106,
      "link": null,
      "locked": false,
      "text": "For each test case, output one integer in one line, denoting the maximum times the win-condition can be played.\n\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "For each test case, output one integer in one line, denoting the maximum times the win-condition can be played.\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "MnATdNt9wFtBQGV_mOt-N",
      "type": "text",
      "x": -3889.7671273578558,
      "y": 1209.4786941792186,
      "width": 32.239959716796875,
      "height": 18.4,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",

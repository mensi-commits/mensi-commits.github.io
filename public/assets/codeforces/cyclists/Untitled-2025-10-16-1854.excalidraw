    {
      "id": "wbcuSEDFqFTPnGiriqMX7",
      "type": "text",
      "x": -3527.3931038457304,
      "y": -33.92514739261472,
      "width": 352.259765625,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",

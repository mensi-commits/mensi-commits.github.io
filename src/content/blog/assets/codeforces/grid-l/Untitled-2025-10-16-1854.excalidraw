      "updated": 1777060393429,
      "link": null,
      "locked": false,
      "text": "Roger has p unit-length segments and q L-shaped pieces, each formed by joining two unit-length segments at a right angle.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Roger has p unit-length segments and q L-shaped pieces, each formed by joining two unit-length segments at a right angle.",
      "autoResize": true,
      "lineHeight": 1.25
    },

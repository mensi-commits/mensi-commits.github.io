    {
      "id": "1CdKSrIEXOi0InwwopRvz",
      "type": "text",
      "x": -4822.890728258133,
      "y": 331.5943409513536,
      "width": 1065.0548095703125,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,

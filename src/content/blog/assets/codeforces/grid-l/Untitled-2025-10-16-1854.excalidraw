      "versionNonce": 2133068317,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777060393429,
      "link": null,
      "locked": false,
      "text": "For each test case, print any valid n and m such that it's possible to construct n×m using all pieces. If there are no such n and m, print \n−1.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "For each test case, print any valid n and m such that it's possible to construct n×m using all pieces. If there are no such n and m, print \n−1.",
      "autoResize": true,
      "lineHeight": 1.25
    },

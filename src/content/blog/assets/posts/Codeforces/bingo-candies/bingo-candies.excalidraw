      "groupIds": [],
      "frameId": null,
      "index": "b13",
      "roundness": null,
      "seed": 1350577181,
      "version": 175,
      "versionNonce": 1842121523,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1773680516957,
      "link": null,
      "locked": false,
      "text": "Let's suppose c is the number of color in a given board, we have 3 situations : \n1. n > c : NO\n2. n = c : YES\n3. n < c : YES",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Let's suppose c is the number of color in a given board, we have 3 situations : \n1. n > c : NO\n2. n = c : YES\n3. n < c : YES",
      "autoResize": true,
      "lineHeight": 1.25
    },

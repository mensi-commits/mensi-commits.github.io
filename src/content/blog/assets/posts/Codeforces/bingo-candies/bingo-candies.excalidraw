    {
      "id": "C9KAQ3NX0WHkR29SMbGXy",
      "type": "text",
      "x": -3837.1540261205055,
      "y": 1665.7026912082288,
      "width": 1089.7431640625,
      "height": 80,
      "angle": 0,

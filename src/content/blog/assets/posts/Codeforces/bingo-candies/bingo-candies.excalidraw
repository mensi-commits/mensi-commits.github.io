    },
    {
      "id": "hnevfX8g2VjU0fa0fcb_6",
      "type": "text",
      "x": 194.55719550700758,
      "y": 801.9954259654753,
      "width": 617.7755126953125,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
